### 2️⃣ Smart‑contract **RoyaltyTracker** (Ethereum‑compatible, Solidity 0.8)

```solidity
// SPDX-License-Identifier: MIT
pragma solidity ^0.8.0;

contract RoyaltyTracker {
    address public owner;
    address public mitterer;               // wallet di Hannes
    uint256 public constant MITTERER_SHARE = 200; // 2.00 % (basis points = 10000)
    uint256 public constant LEX_AMORIS_SHARE = 150; // 1.50 %

    // evento di reporting delle revenue
    event RevenueReported(address indexed reporter, uint256 amount);
    // evento di distribuzione
    event RoyaltyPaid(address indexed beneficiary, uint256 amount);

    modifier onlyOwner() {
        require(msg.sender == owner, "not owner");
        _;
    }

    constructor(address _mitterer) {
        owner = msg.sender;
        mitterer = _mitterer;
    }

    // chiama il team finance ogni trimestre con le revenue nette
    function reportRevenue(uint256 netRevenue) external onlyOwner {
        emit RevenueReported(msg.sender, netRevenue);

        // 2 % per Mitterer (Red Code)
        uint256 mittererAmt = (netRevenue * MITTERER_SHARE) / 10000;
        payable(mitterer).transfer(mittererAmt);
        emit RoyaltyPaid(mitterer, mittererAmt);

        // 1.5 % per Lex Amoris (software con licenza)
        //   (si suppone sia un wallet separato; qui usiamo lo stesso per esempio)
        uint256 lexAmt = (netRevenue * LEX_AMORIS_SHARE) / 10000;
        payable(mitterer).transfer(lexAmt);
        emit RoyaltyPaid(mitterer, lexAmt);
    }

    // riceve ether (es. da Exchange) – fallback
    receive() external payable {}
}
```

*Deploy su **Polygon** o su una side‑chain del Nexus per costi di gas contenuti. Il contrato è chiamato dal **Finance & Payments** del Nexus ogni trimestre con le revenue nette di licensing.*

