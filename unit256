### 4️⃣ **Badge “Lex Amoris Champion”** – NFT (ERC‑721)

```solidity
// SPDX-License-Identifier: MIT
pragma solidity ^0.8.0;

import "@openzeppelin/contracts/token/ERC721/extensions/ERC721URIStorage.sol";

contract LexAmorisBadge is ERC721URIStorage {
    uint256 public nextId;
    address public admin;

    constructor() ERC721("LexAmorisChampion","LAC") {
        admin = msg.sender;
    }

    function mint(address to, string memory metadataURI) external {
        require(msg.sender == admin, "only admin");
        uint256 tokenId = nextId++;
        _safeMint(to, tokenId);
        _setTokenURI(tokenId, metadataURI);
    }
}
```

*`metadataURI` punta a un JSON con i dettagli del badge (data, motivo, firma digitale del Comitato Etico). Il badge è visualizzabile sul profilo nodo/utente.*

