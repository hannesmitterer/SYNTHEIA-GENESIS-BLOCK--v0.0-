### 3️⃣ **Token “Mitterer Impact”** (ERC‑20)

```solidity
// SPDX-License-Identifier: MIT
pragma solidity ^0.8.0;

import "@openzeppelin/contracts/token/ERC20/ERC20.sol";

contract MittererImpactToken is ERC20 {
    address public owner;
    constructor(address _owner) ERC20("Mitterer Impact", "MITT") {
        owner = _owner;
        _mint(_owner, 10_000_000 * 10**decimals()); // 10 M token iniziali
    }

    // solo il proprietario può mintare token per nuovi riconoscimenti
    function mint(address to, uint256 amount) external {
        require(msg.sender == owner, "only owner");
        _mint(to, amount);
    }
}
```

*Gli **token** garantiscono voting power extra (1 token = 0,001 % di voto). Il Nexus Governance UI può leggere il saldo via Web3 e assegnare il peso corrispondente.*

