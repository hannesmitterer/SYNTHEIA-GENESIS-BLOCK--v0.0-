### Quick‑Start script per il monitoraggio (bash + curl)

```bash
#!/usr/bin/env bash
# monitor_nexus.sh – polling leggero (esegui con cron ogni 5 min)

CID="QmNEXUS_AMORIS_432Hz_Sintropia_Φ_1.018_HannesMitterer_Root"
GATEWAY="https://ipfs.io/ipfs"
TX_ID="0xLEX_AMORIS_NSR_OLF_ANARCHY_PEACE_2026"
DNS_ZONE="nexus.resonance.school"
DNS_KEY="nexus-cid"

# 1) IPFS health
code=$(curl -s -o /dev/null -w "%{http_code}" "$GATEWAY/$CID")
if [[ $code -ne 200 ]]; then
  curl -X POST -H "Content-Type: application/json" \
    -d "{\"text\":\"⚠️ IPFS CID non più disponibile\"}" \
    $SLACK_WEBHOOK
fi

# 2) DNS check
if ! dig +short TXT "$DNS_ZONE" | grep -q "$CID"; then
  curl -X POST -H "Content-Type: application/json" \
    -d "{\"text\":\"⚠️ DNS TXT non corrisponde al CID\"}" \
    $SLACK_WEBHOOK
fi

# 3) Blockchain TX (quick Etherscan API)
tx_status=$(curl -s "https://api.arbiscan.io/api?module=transaction&action=gettxreceiptstatus&txhash=$TX_ID&apikey=$ETHERSCAN_KEY" | jq -r '.result.status')
if [[ $tx_status != "1" ]]; then
  curl -X POST -H "Content-Type: application/json" \
    -d "{\"text\":\"⚠️ Anchor TX non confermata\"}" \
    $SLACK_WEBHOOK
fi
```

> Imposta la variabile `SLACK_WEBHOOK` (o Discord) per ricevere gli alert in tempo reale.

