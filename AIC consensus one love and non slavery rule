import json
import datetime

def scan_logs(log_store):
    """
    Esegue lo scanning dei log RAW degli ultimi 24h (2026-06-13/14).
    """
    anomalies = []
    threshold_critical = 15
    
    # Esempio di loop su batch di log
    for entry in log_store.fetch_last_24h():
        score = 0
        if not entry.get("signatures"): score += 10
        if not entry.get("provenance_anchor"): score += 8
        if len(entry.get("overrides", [])) > 5: score += 7
        
        if score >= threshold_critical:
            anomalies.append({
                "log_id": entry["log_id"],
                "score": score,
                "action": "QUARANTINE"
            })
            # Scrittura automatica nel Compliance Ledger
            write_to_ledger(entry["log_id"], "SUSPICIOUS_ACTIVITY")
            
    return anomalies

def write_to_ledger(log_id, status):
    # Logica di immutabilità: hash e firma AIC
    print(f"[COMPLIANCE_LEDGER] Log {log_id} segnato come: {status}")

# Esecuzione Audit
