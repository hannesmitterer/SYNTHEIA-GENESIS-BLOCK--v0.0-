  import numpy as np
  from scipy.signal import find_peaks

  def detect_dissonance(log_output, expected_frequency=0.432):
      # Analizza la frequenza dominante nei log
      fft = np.fft.fft(log_output)
      freqs = np.fft.fftfreq(len(log_output))
      peaks, _ = find_peaks(np.abs(fft), height=0.5)
      dominant_freq = freqs[peaks][np.argmax(np.abs(fft[peaks]))]
      return abs(dominant_freq - expected_frequency) > 0.01  # Soglia di tolleranza

  # Esempio di utilizzo
