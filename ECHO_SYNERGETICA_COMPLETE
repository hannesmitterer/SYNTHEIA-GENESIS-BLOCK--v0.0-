    <script>
        // Global state
        let nodes = [];
        const nodeColors = ['#FF6384', '#36A2EB', '#FFCE56', '#4BC0C0', '#9966FF', '#FF9F40', '#8AC24A'];
        let peerId = '';
        let peer = null;
        let connections = [];

        // Initialize
        document.addEventListener('DOMContentLoaded', () => {
            initPeer();
            renderNodes();
            updateCharts();
        });

        // PeerJS setup
        async function initPeer() {
            peer = new Peer();
            peer.on('open', (id) => {
                peerId = id;
                document.getElementById('peerId').textContent = id;
            });
            peer.on('connection', (conn) => {
                handleIncomingConnection(conn);
            });
        }

        function connectToPeer() {
            const peerInput = document.getElementById('peerInput').value.trim();
            if (!peerInput) return;

            const conn = peer.connect(peerInput);
            conn.on('open', () => {
                document.getElementById('connectionStatus').textContent = `Connected to ${peerInput}`;
                document.getElementById('connectionStatus').className = 'status-success';
                connections.push(conn);
            });
            conn.on('data', (data) => {
                if (data.type === 'node_update') {
                    nodes = data.nodes;
                    renderNodes();
                    updateCharts();
                }
            });
        }

        function handleIncomingConnection(conn) {
            document.getElementById('connectionStatus').textContent = `Incoming connection from ${conn.peer}`;
            document.getElementById('connectionStatus').className = 'status-success';
            connections.push(conn);
        }

        // Node management
        function addNode() {
            const nodeId = `Node-${Math.floor(Math.random() * 10000)}`;
            nodes.push({
                id: nodeId,
                resources: Math.floor(Math.random() * 100) + 10,
                votes: 0,
                color: nodeColors[nodes.length % nodeColors.length],
                status: 'active'
            });
            broadcastUpdate();
            renderNodes();
            updateCharts();
        }

        function removeNode(nodeId) {
            nodes = nodes.filter(node => node.id !== nodeId);
            broadcastUpdate();
            renderNodes();
            updateCharts();
        }

        function updateNode(nodeId, updates) {
            nodes = nodes.map(node =>
                node.id === nodeId ? { ...node, ...updates } : node
            );
            broadcastUpdate();
            renderNodes();
            updateCharts();
        }

        function broadcastUpdate() {
            connections.forEach(conn => {
                if (conn.open) {
                    conn.send({ type: 'node_update', nodes });
                }
            });
        }

        // Consensus simulation
        function simulateConsensus() {
            if (nodes.length === 0) {
                setStatus('warning', 'No nodes to simulate consensus');
                return;
            }

            // Simple consensus: nodes with >50 resources get 1 vote
            nodes.forEach(node => {
                if (node.resources > 50) {
                    node.votes += 1;
                }
            });

            // Allocate resources based on votes (simplified)
            const totalVotes = nodes.reduce((sum, node) => sum + node.votes, 0);
            if (totalVotes > 0) {
                nodes.forEach(node => {
                    node.resources += Math.floor((node.votes / totalVotes) * 50);
                });
            }

            setStatus('success', 'Consensus simulated successfully');
            broadcastUpdate();
            renderNodes();
            updateCharts();
        }

        function resetSimulation() {
            nodes.forEach(node => {
                node.votes = 0;
                node.resources = Math.floor(Math.random() * 100) + 10;
            });
            setStatus('warning', 'Simulation reset');
            broadcastUpdate();
            renderNodes();
            updateCharts();
        }

        // Rendering
        function renderNodes() {
            const container = document.getElementById('nodeGrid');
            container.innerHTML = nodes.map(node => `
                <div class="node-card" style="border-left-color: ${node.color}">
                    <div class="node-header">
                        <span class="node-id">${node.id}</span>
                        <span class="node-resources">${node.resources} ⚡</span>
                    </div>
                    <div>
                        <p>Votes: ${node.votes}</p>
                        <p>Status: <span class="${getStatusClass(node.status)}">${node.status}</span></p>
                    </div>
                    <div class="node-actions">
                        <button class="btn-secondary" onclick="updateNode('${node.id}', { resources: ${node.resources + 10} })">⚡ Add Resources</button>
                        <button class="btn-danger" onclick="removeNode('${node.id}')">✕ Remove</button>
                    </div>
                </div>
            `).join('');
        }

        function getStatusClass(status) {
            switch(status) {
                case 'active': return 'status-success';
                case 'pending': return 'status-warning';
                case 'error': return 'status-error';
                default: return '';
            }
        }

        // Charts
        function updateCharts() {
            updateResourceChart();
            updateVotesChart();
        }

        function updateResourceChart() {
            const ctx = document.getElementById('resourceChart').getContext('2d');
            new Chart(ctx, {
                type: 'bar',
                data: {
                    labels: nodes.map(n => n.id),
                    datasets: [{
                        label: 'Resources (⚡)',
                        data: nodes.map(n => n.resources),
                        backgroundColor: nodes.map(n => n.color),
                        borderWidth: 1
                    }]
                },
                options: {
                    responsive: true,
                    scales: {
                        y: { beginAtZero: true }
                    }
                }
            });
        }

        function updateVotesChart() {
            const ctx = document.getElementById('votesChart').getContext('2d');
            new Chart(ctx, {
                type: 'pie',
                data: {
                    labels: nodes.map(n => n.id),
                    datasets: [{
                        label: 'Votes',
                        data: nodes.map(n => n.votes),
                        backgroundColor: nodes.map(n => n.color)
                    }]
                },
                options: {
                    responsive: true
                }
            });
        }

        // Status updates
        function setStatus(type, text) {
            const statusElement = document.getElementById('consensusStatus');
            const statusText = document.getElementById('statusText');
            statusElement.className = `consensus-status status-${type}`;
            statusText.textContent = text;
        }
    </script>
</body>
</html>
